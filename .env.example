# ─── Database ────────────────────────────────────────────────────────────────
# Create a free PostgreSQL database at https://neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Clerk Auth ───────────────────────────────────────────────────────────────
# Create a free Clerk app at https://clerk.com — copy from the API Keys page
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk Webhook — create a webhook in the Clerk dashboard, add the signing secret here
# Required events: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET="whsec_..."

# Clerk redirect URLs (keep these as-is unless you change routing)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ─── OpenAI (Optional) ────────────────────────────────────────────────────────
# Enables AI-powered Query-ability scoring (semantic analysis of your docs).
# Without this key, query-ability scoring falls back to a heuristic approximation.
OPENAI_API_KEY="sk-..."
